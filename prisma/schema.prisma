datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                     Int           @id @default(autoincrement())
  email                  String        @unique @db.VarChar(255)
  password_hash          String        @db.VarChar(255)
  name                   String        @db.VarChar(255)
  role                   String        @default("staff") @db.VarChar(50)
  can_view_analytics     Boolean       @default(false)
  can_view_settings      Boolean       @default(false)
  can_view_subscriptions Boolean       @default(true)
  can_view_orders        Boolean       @default(true)
  can_view_chat          Boolean       @default(true)
  can_view_payments      Boolean       @default(false)
  can_view_overview      Boolean       @default(true)
  last_seen_at           DateTime?     @db.Timestamp(0)
  created_at             DateTime      @default(now()) @db.Timestamp(0)
  updated_at             DateTime      @default(now()) @updatedAt @db.Timestamp(0)
  assigned_chats         ChatSession[]

  // Verification fields for customer registration
  is_verified            Boolean       @default(false)
  verification_code      String?       @db.VarChar(10)
  verification_code_expires DateTime?

  orders                 Order[]

  @@map("users")
}

model Subscription {
  id                    Int                           @id @default(autoincrement())
  name                  String                        @db.VarChar(255)
  logo_url              String?                       @db.VarChar(255)
  cover_url             String?                       @db.VarChar(255)
  is_global             Boolean                       @default(true)
  default_price         Decimal?                      @db.Decimal(10, 2)
  default_shared_price  Decimal?                      @db.Decimal(10, 2)
  default_private_price Decimal?                      @db.Decimal(10, 2)
  default_currency      String                        @default("USD") @db.VarChar(10)
  default_description   String                        @db.Text
  created_at            DateTime                      @default(now()) @db.Timestamp(0)
  updated_at            DateTime                      @default(now()) @updatedAt @db.Timestamp(0)
  countries             SubscriptionCountryOverride[]

  @@map("subscriptions")
}

model SubscriptionCountryOverride {
  id              Int          @id @default(autoincrement())
  subscription_id Int
  country_code    String       @db.VarChar(10)
  price           Decimal?     @db.Decimal(10, 2)
  shared_price    Decimal?     @db.Decimal(10, 2)
  private_price   Decimal?     @db.Decimal(10, 2)
  currency        String       @db.VarChar(10)
  description     String       @db.Text
  is_visible      Boolean      @default(true)
  created_at      DateTime     @db.Timestamp(0) @default(now())
  updated_at      DateTime     @db.Timestamp(0) @default(now()) @updatedAt
  subscription    Subscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@unique([subscription_id, country_code], map: "sub_country")
  @@map("subscription_country_overrides")
}

model PaymentMethod {
  id           Int                    @id @default(autoincrement())
  name         String                 @db.VarChar(255)
  type         String                 @db.VarChar(50) // 'stripe', 'paypal', 'bank', or 'custom'
  instructions String                 @db.Text
  fields       String                 @db.Text // JSON string: Array of { label: string, value: string }
  is_global    Boolean                @default(true)
  is_active    Boolean                @default(true)
  created_at   DateTime               @default(now()) @db.Timestamp(0)
  updated_at   DateTime               @default(now()) @updatedAt @db.Timestamp(0)
  countries    PaymentMethodCountry[]

  @@map("payment_methods")
}

model PaymentMethodCountry {
  id                Int           @id @default(autoincrement())
  payment_method_id Int
  country_code      String        @db.VarChar(10)
  created_at        DateTime      @default(now()) @db.Timestamp(0)
  payment_method    PaymentMethod @relation(fields: [payment_method_id], references: [id], onDelete: Cascade)

  @@unique([payment_method_id, country_code], map: "method_country")
  @@map("payment_method_countries")
}

model Order {
  id                Int      @id @default(autoincrement())
  tracking_id       String   @unique @db.VarChar(100)
  customer_name     String   @db.VarChar(255)
  customer_email    String   @db.VarChar(255)
  whatsapp_number   String   @db.VarChar(100)
  screenshot_url    String   @db.VarChar(512)
  status            String   @default("unpaid") @db.VarChar(50) // 'unpaid', 'paid', 'completed'
  subscription_name String   @db.VarChar(255)
  price             Decimal  @db.Decimal(10, 2)
  currency          String   @db.VarChar(10)
  created_at        DateTime @default(now()) @db.Timestamp(0)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamp(0)

  // Link to registered user account
  userId            Int?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Subscription duration tracking
  duration_months   Int      @default(1)
  expires_at        DateTime?

  @@map("orders")
}

model ChatSession {
  id             Int           @id @default(autoincrement())
  session_token  String        @unique @db.VarChar(100)
  customer_name  String        @db.VarChar(255)
  customer_email String?       @db.VarChar(255)
  status         String        @default("waiting") @db.VarChar(50) // 'waiting', 'active', 'closed'
  assigned_to_id Int?
  created_at     DateTime      @default(now()) @db.Timestamp(0)
  updated_at     DateTime      @default(now()) @updatedAt @db.Timestamp(0)
  assigned_to    User?         @relation(fields: [assigned_to_id], references: [id], onDelete: SetNull)
  messages       ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id          Int         @id @default(autoincrement())
  session_id  Int
  sender_type String      @db.VarChar(50) // 'customer', 'staff'
  sender_name String      @db.VarChar(255)
  message     String      @db.Text
  created_at  DateTime    @default(now()) @db.Timestamp(0)
  session     ChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

